{
  "name": "runwa",
  "version": "0.1.14",
  "description": "A cross-platform command palette launcher",
  "main": "./out/main/index.js",
  "author": "dmitr",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:native": "cd native && napi build --platform --release",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "dist:mac": "electron-vite build && electron-builder --mac --publish=never && node scripts/mac-restamp-signature.mjs",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "fuse.js": "^7.0.0",
    "immer": "^11.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "uiohook-napi": "^1.5.4",
    "uuid": "^11.0.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "husky": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  }
}
